@using WebNet23Online.Models.RockBands
@using WebNet23Online.Localizations
@model RockBandsIndexViewModel
@{
    Layout = "_LayoutRockBands";
}
<title>@RockBand.Index_Title</title>
<link rel="stylesheet" href="/css/rock-bands/style-band.css">
<header>
    <h1>@RockBand.Index_Header</h1>
    <p>@RockBand.Index_Header_Description</p>
    <a href="/">@RockBand.Index_Header_Home</a>
</header>

<main>

    <div class="rock-bands-page">
        <section class="genre-filter">
            <div class="preferences-music-title">
                <h2>@RockBand.Index_ChooseGenres</h2>
            </div>

            <form method="get" asp-controller="RockBands" asp-action="Index">
                <div class="genre-filter-list">
                    @foreach (var g in Model.Genres)
                    {
                        var inputId = $"genre_{g.Id}";
                        <input class="genre-filter-checkbox"
                               type="checkbox"
                               id="@inputId"
                               name="genreIds"
                               value="@g.Id"
                               @(g.IsSelected ? "checked" : null) />
                        <label class="genre-filter-chip" for="@inputId">@g.Name</label>
                    }
                </div>

                <div class="genre-filter-actions">
                    <button type="submit" class="add-band-submit">@RockBand.Index_Show_Button</button>
                    <a class="add-band-submit" asp-controller="RockBands" asp-action="Index">@RockBand.Index_Reset_button</a>
                </div>
            </form>
        </section>

        @foreach (var band in Model.Bands)
        {
            <div class="band">
                <div class="band-thumb">
                    @if (!string.IsNullOrWhiteSpace(band.ImageUrl))
                    {
                        <img src="@band.ImageUrl" alt="@band.Name" width="640" height="360" loading="lazy" referrerpolicy="no-referrer">
                    }
                    else
                    {
                        <img alt="@band.Name">
                    }
                </div>
                <div class="band-body">
                    <h2>@band.Name</h2>
                    <p>@band.Description</p>
                    @if (!string.IsNullOrWhiteSpace(band.CreatedByUserName))
                    {
                        <p><strong>@RockBand.Index_Add_By_User</strong> @band.CreatedByUserName</p>
                    }

                    @if (band.Genres != null && band.Genres.Count > 0)
                    {
                        <p><strong>@RockBand.Index_ChooseGenres</strong> @string.Join(", ", band.Genres)</p>
                    }
                </div>
            </div>
        }

        @if (Model.CanEditRockBandGenres)
        {
            <section class="preferences-music edit-band-genres-form">
                <div class="preferences-music-title">
                    <h2>@RockBand.Index_Edit_Genres</h2>
                    <p class="add-band-form-hint">@RockBand.Index_Edit_Instruction</p>
                </div>
                <div class="preferences-music-items edit-band-genres-panel">
                    <form method="get" asp-controller="RockBands" asp-action="Index" class="edit-band-genres-toolbar">
                        @foreach (var id in Model.SelectedGenreIds)
                        {
                            <input type="hidden" name="genreIds" value="@id" />
                        }
                        <div class="edit-band-genres-field">

                            <select id="select_band" class="edit-band-genres-select" name="editBandId">
                                <option value="">@RockBand.Index_Edit_Choose</option>
                                @foreach (var b in Model.Bands)
                                {
                                    <option value="@b.Id" selected="@(Model.EditBandId == b.Id)">@b.Name</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="add-band-submit">@RockBand.Index_Edit_Button</button>
                    </form>

                    @{
                        var editBand = Model.EditBandId.HasValue
                            ? Model.Bands.FirstOrDefault(x => x.Id == Model.EditBandId.Value)
                            : null;
                    }

                    @if (editBand != null)
                    {
                        <form method="post" asp-controller="RockBands" asp-action="UpdateGenres" class="edit-band-genres-item">
                            <input type="hidden" name="bandId" value="@editBand.Id" />
                            <div class="edit-band-genres-header">
                                <strong>@editBand.Name</strong>
                            </div>
                            <div class="genre-filter-list genre-filter-list-compact">
                                @foreach (var g in Model.Genres)
                                {
                                    var inputId = $"edit_{editBand.Id}_{g.Id}";
                                    var isChecked = editBand.GenreIds != null && editBand.GenreIds.Contains(g.Id);
                                    <input class="genre-filter-checkbox"
                                           type="checkbox"
                                           id="@inputId"
                                           name="selectedGenreIds"
                                           value="@g.Id"
                                           @(isChecked ? "checked" : null) />
                                    <label class="genre-filter-chip" for="@inputId">@g.Name</label>
                                }
                            </div>
                            <div class="edit-band-genres-actions">
                                <button type="submit" class="add-band-submit">@RockBand.Index_Edit_Save_Button</button>
                            </div>
                        </form>
                    }
                </div>
            </section>
        }
        else if (Model.IsUserAuth)
        {
            <section class="preferences-music edit-band-genres-form">
                <div class="preferences-music-title">
                    <h2>@RockBand.Index_Edit_Genres</h2>
                    <p class="add-band-form-hint">@RockBand.Index_Edit_Error</p>
                </div>
            </section>
        }
        else
        {
            <section class="preferences-music edit-band-genres-form">
                <div class="preferences-music-title">
                    <h2>@RockBand.Index_Edit_Genres</h2>
                    <p class="add-band-form-hint">
                        @RockBand.Index_Edit_Needed
                        <a asp-controller="Auth" asp-action="Login">@RockBand.Index_Edit_Log_In</a>
                        @RockBand.Index_Edit_Or
                        <a asp-controller="Auth" asp-action="Registration">@RockBand.Index_Edit_Register</a>.
                    </p>
                </div>
            </section>
        }

        @if (Model.IsUserAuth)
        {
            <section class="preferences-music add-band-form">
                <div class="preferences-music-title">
                    <h2>@RockBand.Index_Add_Header</h2>
                    <p class="add-band-form-hint">@RockBand.Index_Add_Description</p>
                </div>
                <div class="preferences-music-items add-band-form-panel">
                    <form method="post" class="add-band-form-fields">
                        <div class="add-band-field">
                            <label for="band-name">@RockBand.Index_Add_Name</label>
                            <input id="band-name" type="text" asp-for="BandBlock.Name" placeholder=@RockBand.Index_Add_Name_Example autocomplete="off" />
                            @Html.ValidationMessageFor(m => m.BandBlock.Name)
                        </div>
                        <div class="add-band-field">
                            <label for="band-description">@RockBand.Index_Add_Card_Description</label>
                            <textarea id="band-description" asp-for="BandBlock.Description" placeholder=@RockBand.Index_Add_Description_Example rows="4"></textarea>
                            @Html.ValidationMessageFor(m => m.BandBlock.Description)
                        </div>
                        <div class="add-band-field">
                            <label for="band-image">@RockBand.Index_Add_Image</label>
                            <input id="band-image" type="text" inputmode="url" asp-for="BandBlock.ImageUrl" placeholder=@RockBand.Index_Add_Image_Example spellcheck="false" autocomplete="off" />
                            <span class="add-band-field-help">@RockBand.Index_Add_Image_Description</span>
                            @Html.ValidationMessageFor(m => m.BandBlock.ImageUrl)
                        </div>
                        <div class="add-band-field">
                            <label>@RockBand.Index_Add_Genres</label>
                            <div class="genre-filter-list genre-filter-list-compact">
                                @foreach (var g in Model.Genres)
                                {
                                    var inputId = $"add_genre_{g.Id}";
                                    <input class="genre-filter-checkbox"
                                           type="checkbox"
                                           id="@inputId"
                                           name="BandBlock.SelectedGenreIds"
                                           value="@g.Id" />
                                    <label class="genre-filter-chip" for="@inputId">@g.Name</label>
                                }
                            </div>
                        </div>
                        <button type="submit" class="add-band-submit">@RockBand.Index_Add_Button</button>
                    </form>
                </div>
            </section>
        }
        else
        {
            <section class="preferences-music add-band-form">
                <div class="preferences-music-title">
                    <h2>@RockBand.Index_Add_Header</h2>
                    <p class="add-band-form-hint">
                        @RockBand.Index_Add_Needed
                        <a asp-controller="Auth" asp-action="Login">@RockBand.Index_Edit_Log_In</a>
                        @RockBand.Index_Edit_Or
                        <a asp-controller="Auth" asp-action="Registration">@RockBand.Index_Edit_Register</a>.
                    </p>
                </div>
            </section>
        }
    </div>
</main>
