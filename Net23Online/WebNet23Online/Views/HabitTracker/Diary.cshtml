@{
    Layout = "_LayoutHabitTracker";
}

<link rel="stylesheet" href="/css/habit-tracker/diary.css">

<div class="tracker">
    <div class="tracker-title">Дневник</div>
    <div class="tracker-date">Нажми на день чтобы добавить запись</div>

    <div class="diary-wrapper">
        <div class="calendar-header">
            <button class="calendar-nav" id="prev">←</button>
            <span id="month-title"></span>
            <button class="calendar-nav" id="next">→</button>
        </div>
        <div class="calendar-grid" id="calendar"></div>
    </div>
</div>


<div class="popup-overlay" id="popup-overlay">
    <div class="popup">
        <div class="popup-date" id="popup-date"></div>
        <textarea id="popup-text" placeholder="Напиши что-нибудь..."></textarea>
        <div class="popup-buttons">
            <button class="btn-cancel" id="btn-cancel">Отмена</button>
            <button class="btn-save" id="btn-save">Сохранить</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="/js/habit-tracker/diary.js"></script>
}