@model List<WebNet23Online.Models.HabitTracker.AdminUserViewModel>
@{
    Layout = "_LayoutHabitTracker";
}

<link rel="stylesheet" href="/css/habit-tracker/statistics.css">

<div class="tracker">
    <div class="tracker-title">Список пользователей</div>

    <div class="table-tracker stats-container">
        @foreach (var user in Model)
        {
            <div class="stat-item">
                <div class="stat-header">
                    <span class="stat-name">@user.Name (@user.Role)</span>
                    <span class="stat-value">Привычек: @user.HabitsCount</span>
                </div>
                <form method="post" asp-action="ToggleBlock">
                    <input type="hidden" name="userId" value="@user.Id" />
                    <button type="submit" class="btn-action @(user.IsBlocked ? "btn-add" : "btn-delete")">
                        @(user.IsBlocked ? "Разблокировать" : "Заблокировать")
                    </button>
                </form>
            </div>
        }
    </div>
</div>