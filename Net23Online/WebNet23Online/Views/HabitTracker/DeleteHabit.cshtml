@using WebNet23Online.Models.HabitTracker
@model HabitTrackerViewModel

@{
    Layout = "_LayoutHabitTracker";
}

<link rel="stylesheet" href="/css/habit-tracker/settings.css">

<div class="settings-card">
    <div class="settings-card-header">
        <span class="settings-icon">✕</span>
        <h3>Удалить привычку</h3>
    </div>

    <form method="post">
        <div class="form-group">
            <label>Выберите привычку</label>

            @Html.DropDownList("habitId", Model.Habits.Select(x => new SelectListItem {
                    Value = x.Id.ToString(),
                    Text = x.Title
                }), 
                "— выберите —", 
                new { @class = "input-field" })
        </div>

        <button type="submit" class="btn-action btn-delete">Удалить</button>
    </form>
</div>