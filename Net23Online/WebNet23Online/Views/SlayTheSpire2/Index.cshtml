@{
    Layout = "_LayoutSLayTheSpire";
}
<div class="spire-index">
        <header class="page-intro">
            <div class="spire-quote-line" aria-hidden="true"></div>
            <p class="spire-quote">«Тысячу лет Шпиль дремал... Теперь он вновь открылся, ещё более голодный и опасный, чем когда-либо, пожирая всех, кто осмелится подняться наверх»</p>
            <div class="spire-quote-line spire-quote-line-bottom" aria-hidden="true"></div>
        </header>
        <div class="heroes">
            <div class="hero">
                <div class="image-container">
                    <a asp-controller="SlayTheSpire2" asp-action="Heroes" asp-route-id="1" class="hero-image-link" aria-label="Ironclad — открыть данные героя">
                        <img src="/images/slay-the-spire-2/Ironclad.jpg" alt="Ironclad" />
                    </a>
                </div>
                <div class="hero-name">Ironclad</div>
            </div>
            <div class="hero">
                <div class="image-container">
                    <a asp-controller="SlayTheSpire2" asp-action="Heroes" asp-route-id="2" class="hero-image-link" aria-label="Silent — открыть данные героя">
                        <img src="/images/slay-the-spire-2/Silent.jpg" alt="Silent" />
                    </a>
                </div>
                <div class="hero-name">Silent</div>
            </div>
        </div>
        <div class="heroes">
            <div class="hero">
                <div class="image-container">
                    <a asp-controller="SlayTheSpire2" asp-action="Heroes" asp-route-id="3" class="hero-image-link" aria-label="Regent — открыть данные героя">
                        <img src="/images/slay-the-spire-2/Regent.jpg" alt="Regent" />
                    </a>
                </div>
                <div class="hero-name">Regent</div>
            </div>
            <div class="hero">
                <div class="image-container">
                    <a asp-controller="SlayTheSpire2" asp-action="Heroes" asp-route-id="4" class="hero-image-link" aria-label="Necrobinder — открыть данные героя">
                        <img src="/images/slay-the-spire-2/Necrobinder.jpg" alt="Necrobinder" />
                    </a>
                </div>
                <div class="hero-name">Necrobinder</div>
            </div>
        </div>
        <div class="heroes">
            <div class="hero">
                <div class="image-container">
                    <a asp-controller="SlayTheSpire2" asp-action="Heroes" asp-route-id="5" class="hero-image-link" aria-label="Defect — открыть данные героя">
                        <img src="/images/slay-the-spire-2/Defect.jpg" alt="Defect" />
                    </a>
                </div>
                <div class="hero-name">Defect</div>
            </div>
        </div>
        <div class="heroes heroes-triple">
            <div class="hero">
                <div class="image-container">
                    <a asp-controller="SlayTheSpire2" asp-action="KickStarter" class="hero-image-link">
                        <img src="/images/slay-the-spire-2/BoardGame.jpg" alt="Board game — открыть страницу Kickstarter" />
                    </a>
                </div>
            </div>
            <div class="hero">
                <div class="image-container">
                    <img src="/images/slay-the-spire-2/3Heroes.jpg" />
                </div>
            </div>
            <div class="hero">
                <div class="image-container">
                    <img src="/images/slay-the-spire-2/ImageFromSteam.jpg" />
                </div>
            </div>
        </div>
</div>
