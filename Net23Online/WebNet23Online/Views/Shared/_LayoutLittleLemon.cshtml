<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebNet23Online</title>
    <link rel="stylesheet" href="/css/little-lemon/home-page-styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="/css/little-lemon/reservation.css" asp-append-version="true" />
</head>
<body>
    <header class="header">
        <div class="header-container">
            <h1 class="header-title">Little Lemon restaurant</h1>
            <a href="index.html">
                <img src="/images/little-lemon/icons/logo.png"
                     alt="Little Lemon logo"
                     width="202"
                     height="50"
                     class="header-logo" />
            </a>
            <nav class="header-navbar">
                <ul class="navbar">
                    <li><a href="/LittleLemon/Index">Home</a></li>
                    <li><a href="#menu">Menu</a></li>
                    <li><a href="#about">About</a></li>
                    <li><a href="/LittleLemon/Reservation">Reservation</a></li>
                    <li><a href="#">Order Online</a></li>
                    <li><a href="#footer">Contact</a></li>
                    <li><a href="#">Login</a></li>
                </ul>
            </nav>
        </div>
    </header>
        <main role="main" >
            @RenderBody()
        </main>

    <footer id="footer" class="footer">
        <div class="footer-container">
            <div class="footer-content-left">
                <div class="footer-logo">
                    <img src="/images/little-lemon/icons/logo.png"
                         alt="Little Lemon logo"
                         width="400"
                         height="100" />
                </div>
                <div class="social-links">
                    <ul class="social-links-list">
                        <li>
                            <a href="https://www.facebook.com/" class="social-link">
                                <i class="social-icon icon-1"></i>
                                <span>Facebook</span>
                            </a>
                        </li>
                        <li>
                            <a href="https://twitter.com/" class="social-link">
                                <i class="social-icon icon-2"></i>
                                <span>Twitter</span>
                            </a>
                        </li>
                        <li>
                            <a href="https://www.instagram.com/" class="social-link">
                                <i class="social-icon icon-3"></i>
                                <span>Instagram</span>
                            </a>
                        </li>
                        <li>
                            <a href="https://www.youtube.com/" class="social-link">
                                <i class="social-icon icon-4"></i>
                                <span>Youtube</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
            <div class="footer-content-middle">
                <nav class="footer-navigation">
                    <ul class="navbar">
                        <li><a href="/LittleLemon/Index">home</a></li>
                        <li><a href="#about">about</a></li>
                        <li><a href="#menu">Menu</a></li>
                        <li>
                            <a href="/LittleLemon/Reservation">reservations</a>
                        </li>
                        <li><a href="#menu">order online</a></li>
                        <li><a href="#">login</a></li>
                    </ul>
                </nav>
            </div>
            <div class="footer-content-right">
                <form class="form" action="#" method="get">
                    <label for="subscribe">Subscribe!</label>
                    <div>
                        <input type="email"
                               name="email"
                               id="subscribe"
                               placeholder="Type your E-mail"
                               required
                               autocomplete="email" />
                        <input type="submit" value="submit" />
                    </div>
                </form>
                <div class="address">
                    <p>53, East Birchwood Ave. Brooklyn, New York 11201, USA.</p>
                    <p>contact@littlelemon.com</p>
                    <p>(123) 456 - 7890</p>
                </div>
            </div>
        </div>
    </footer>
</body>
</html>
