@using System.Security.Claims

@using WebNet23Online.Localizations.Steam
@using WebNet23Online.Services
@using WebNet23Online.Services.Interfaces
@inject IAuthService authService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/steam/styles.css">
</head>
<body>
    <header class="site-header">
        <div class="topbar">
            <a class="brand" href="/Steam/Index">STEAM</a>

            <nav class="primary-nav">
                <ul class="nav-list">
                    <li><a href="/Steam/Index">@SteamShared.Primary_Nav_Store</a></li>
                    <li><a href="/Steam/Catalog">@SteamShared.Primary_Nav_Catalog</a></li>
                    <li><a href="/community">@SteamShared.Primary_Nav_Community</a></li>
                    <li><a href="/about">@SteamShared.Primary_Nav_About</a></li>
                    <li><a href="/support">@SteamShared.Primary_Nav_Support</a></li>
                </ul>
            </nav>

            <div class="topbar-actions">
                <form class="search">
                    <input name="q" type="search" placeholder="@SteamShared.Top_Bar_Search_Placeholder" />
                    <button type="submit">@SteamShared.Top_Bar_Search_Button</button>
                </form>

                <a class="install" href="/install">@SteamShared.Top_Bar_Install_Button</a>

                <div class="auth-buttons">
                    @if (authService.IsAuthenticated())
                    {
                        <div class="user-info">
                            @if (!string.IsNullOrEmpty(authService.GetUser()?.AvatarUrl))
                            {
                                <img src="@authService.GetUser().AvatarUrl" alt="Avatar" class="user-avatar-small" />
                            }
                            else
                            {
                                <div class="user-avatar-placeholder-small"></div>
                            }
                            <a class="username-link" href="/User/SteamUserProfile">@SteamShared.Top_Bar_Welcome_Text, @authService.GetUserName()!</a>
                        </div>
                        <a class="logout-btn" href="/Auth/Logout">@SteamShared.Top_Bar_Logout_Button</a>
                    }
                    else
                    {
                        <a class="login-btn" href="/Auth/Login">@SteamShared.Top_Bar_Login_Button</a>
                        <a class="register-btn" href="/Auth/Registration">@SteamShared.Top_Bar_Register_Button</a>
                    }
                </div>

                <a class="back-to-home" href="/Home/Index">@SteamShared.Top_Bar_All_Projects_Button</a>
            </div>
        </div>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <footer class="footer">
        <div class="footer-inner">
            <div class="footer-top">
                <div class="footer-logo">STEAM</div>
                <div class="footer-links">
                    <a href="#">@SteamShared.Footer_About_Company</a>
                    <a href="#">@SteamShared.Footer_Jobs</a>
                    <a href="#">@SteamShared.Footer_Steamworks</a>
                    <a href="#">@SteamShared.Footer_Support</a>
                    <a href="#">@SteamShared.Footer_Privacy_Policy</a>
                    <a href="#">@SteamShared.Footer_Legal</a>
                </div>
            </div>

            <div class="footer-bottom">
                <p>
                    © 2026 Nikita Corporation. All rights reserved. All trademarks are property of their respective owners.
                </p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
