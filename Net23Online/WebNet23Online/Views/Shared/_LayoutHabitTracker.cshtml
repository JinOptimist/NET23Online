@using WebNet23Online.Services.Interfaces
@inject IAuthService authService

<!DOCTYPE html>
<html>
<head>
    <meta charset='utf-8'>
    <meta name='viewport' content='width=device-width, initial-scale=1'>
    <title>@ViewData["Title"] - WebNet23Online</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebNet23Online.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="/css/habit-tracker/main.css">
</head>

<body>
<header>
    <div class="header-content">
        <div class="header-left">
            <div class="logo"><h1>Habit-tracker</h1></div>
            <div class="tagline">Начни сегодня</div>
        </div>
        <img class="ava" src="/images/habit-tracker/avatarka.jpg">
    </div>
</header>

<div class="main-content">
    <nav>
        <ul>
            @if (!authService.IsAuthenticated())
            {
                <li><a asp-area="" asp-controller="Auth" asp-action="Login">Войти</a></li>
                <li><a asp-area="" asp-controller="Auth" asp-action="Registration">Зарегистрироваться</a></li>
                <li><a asp-area="" asp-controller="HabitTracker" asp-action="Index">Информация</a></li>
            }
            else if (authService.IsUser())
            {
                <li><a asp-controller="HabitTracker" asp-action="HabitTracker">Трекер задач</a></li>
                <li><a asp-controller="HabitTracker" asp-action="Statistics">Статистика</a></li>
                <li><a asp-controller="HabitTracker" asp-action="Diary">Дневник</a></li>
                <li><a asp-controller="HabitTracker" asp-action="Settings">Настройки</a></li>
                <li><a asp-area="" asp-controller="HabitTracker" asp-action="Index">Информация</a></li>
                <li><a asp-area="" asp-controller="Auth" asp-action="Logout">Выйти из аккаунта</a></li>
            }
            else if (authService.AtLeastModerator())
            {
                <li><a asp-controller="HabitTracker" asp-action="AdminPanel">Общая статистика</a></li>
                <li><a asp-controller="HabitTracker" asp-action="UserList">Список пользователей</a></li>
            }
            <li><a asp-area="" asp-controller="Home" asp-action="Index">Дом</a></li>
        </ul>
    </nav>

    @RenderBody()

</div>

@RenderSection("Scripts", required: false)
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const currentPath = window.location.pathname.toLowerCase();

        document.querySelectorAll('nav a').forEach(link => {
            const href = (link.getAttribute('href') || '').toLowerCase();

            if (!href || href === '#') return;

            // Убираем trailing slash у обоих для сравнения
            const cleanCurrent = currentPath.replace(/\/$/, '');
            const cleanHref = href.replace(/\/$/, '');

            // Точное совпадение
            if (cleanCurrent === cleanHref) {
                link.classList.add('active');
                return;
            }

            // Для страниц HabitTracker: подсвечиваем конкретное действие
            if (cleanCurrent.startsWith('/habittracker/')) {
                const action = cleanCurrent.split('/')[2]; // например "statistics", "diary" и т.д.

                if (cleanHref.includes('/habittracker/' + action)) {
                    link.classList.add('active');
                }
            }
        });
    });
</script>
</body>
</html>

