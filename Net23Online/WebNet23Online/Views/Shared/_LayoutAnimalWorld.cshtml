@using WebNet23Online.Localizations
@using WebNet23Online.Services.Interfaces
@inject IAuthService authService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebNet23Online</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebNet23Online.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/animal-world/animal-world-style.css" />
</head>
<body>
    <div class="header-body">
        <h1>@AnimalWorld.AmazingAnimalWorld</h1>
        <div class="header-links">
            <a class="header-link" href="/">@AnimalWorld.OnIndex</a>
            <a class="header-link" href="/AnimalWorld/Index">@AnimalWorld.AnimalWorld</a>
            @if (authService.IsAuthenticated())
            {
                <a class="header-link" href="/AnimalWorld/Zoos">@AnimalWorld.Reservation</a>
            }
            @if (authService.AtLeastModerator())
            {
                <a class="header-link" href="/AnimalWorld/Add">@AnimalWorld.AddData</a>
            }
            <a class="header-link" href="">@AnimalWorld.Interesting</a>
        </div>
    </div>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container footer-body">
            <p>@AnimalWorld.FooterText</p>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/jquery/jquery.unobtrusive-ajax.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
