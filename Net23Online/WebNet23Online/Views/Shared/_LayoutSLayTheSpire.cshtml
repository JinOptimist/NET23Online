<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WebNet23Online</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebNet23Online.styles.css" asp-append-version="true" />

    <link rel="stylesheet" href="~/css/slay-the-spire-2/style.css" asp-append-version="true" />
</head>
<body>
    <header class="spire-navbar">
        <a class="spire-navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">WebNet23Online</a>
        <nav class="spire-navbar-nav" aria-label="Меню">
            <a class="spire-navbar-link" asp-area="" asp-controller="SlayTheSpire2" asp-action="Index">Главная</a>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
</body>
</html>
