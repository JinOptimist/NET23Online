@using WebNet23Online.Localizations
@model WebNet23Online.Models.AnimalWorld.AnimalSpeciesViewModel
@{
    Layout = "_LayoutAnimalWorld";
}

<title>@AnimalWorld.AddAnimalSpecies</title>

<div class="main-place">
    <div class="green-title">
        <h2>@AnimalWorld.AddAnimalSpecies</h2>
    </div>
    <hr class="green-line">
    <form method="post" enctype="multipart/form-data">
        <div class="form-group">
            <div class="green-title">
                <h6>@AnimalWorld.SpeciesName</h6>
            </div>
            @Html.TextBoxFor(species => species.AnimalSpeciesName, new { @class = "form-input", type = "text", placeholder = AnimalWorld.AnimalSpeciesExample })
            @Html.ValidationMessageFor(species => species.AnimalSpeciesName)
        </div>
        <div class="form-group">
            <div class="green-title">
                <h6>@AnimalWorld.UploadImage</h6>
            </div>
            <input type="file" name="AnimalSpeciesImage" class="form-input file-input" accept="image/*" />
        </div>
        <div class="form-group">
            <div class="green-title">
                <h6>@AnimalWorld.AnimalFamily</h6>
            </div>
            @Html.DropDownListFor(species => species.AnimalFamilyId, Model.AnimalFamilyNames, AnimalWorld.ChooseAnimalFamily, new { @class = "form-input" })
            @Html.ValidationMessageFor(species => species.AnimalFamilyId)
        </div>
        <div class="form-group">
            <div class="green-title">
                <h6>@AnimalWorld.Habitat</h6>
            </div>
            @Html.TextBoxFor(species => species.NativeRange, new { @class = "form-input", type = "text", placeholder = AnimalWorld.HabitatExample })
            @Html.ValidationMessageFor(species => species.NativeRange)
        </div>
        <div class="form-group">
            <div class="green-title">
                <h6>@AnimalWorld.AnimalSpeciesSummary</h6>
            </div>
            @Html.TextAreaFor(species => species.Description, new { @class = "form-input", placeholder = AnimalWorld.AnimalSpeciesSummary + "..." })
            @Html.ValidationMessageFor(species => species.Description)
        </div>
        <div class="button-group">
            <button class="find-animal-button" type="submit">@AnimalWorld.Add</button>
        </div>
    </form>
</div>
