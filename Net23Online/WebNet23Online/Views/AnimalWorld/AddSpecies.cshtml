@model WebNet23Online.Models.AnimalWorld.AnimalSpeciesViewModel
@{
    Layout = "_LayoutAnimalWorld";
    ViewData["Title"] = "Добавить вид";
    var familyOptions = ViewBag.AnimalFamilyOptions as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
        ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
}

<div class="main-place">
    <div class="green-title">
        <h2>Добавление вида животных</h2>
    </div>
    <hr class="green-line">
    <form method="post" asp-controller="AnimalWorld" asp-action="AddSpecies" class="entity-form">
        <div class="form-group">
            <div class="green-title">
                <h6>Название вида</h6>
            </div>
            @Html.TextBoxFor(species => species.AnimalSpeciesName, new { @class = "form-input", type = "text", placeholder = "Например: Panthera leo" })
        </div>

        <div class="form-group">
            <div class="green-title">
                <h6>Род</h6>
            </div>
            @Html.DropDownListFor(species => species.AnimalFamilyName, familyOptions, "Выберите род", new { @class = "form-input" })
        </div>

        <div class="form-group">
            <div class="green-title">
                <h6>Ареал обитания</h6>
            </div>
            @Html.TextBoxFor(species => species.NativeRange, new { @class = "form-input", type = "text", placeholder = "Например: Саванны Африки" })
        </div>

        <div class="form-group">
            <div class="green-title">
                <h6>Описание вида</h6>
            </div>
            @Html.TextAreaFor(species => species.Description, new { @class = "form-input", placeholder = "Краткое описание вида..." })
        </div>

        <div class="button-group">
            <button class="find-animal-button" type="submit">Сохранить</button>
            <a class="find-animal-button add-link-button secondary-action" asp-controller="AnimalWorld" asp-action="Add">Назад</a>
        </div>
    </form>
</div>
