@model WebNet23Online.Models.AnimalWorld.StartPageAnimalWorldInfoViewModel
@{
    Layout = "_LayoutAnimalWorld";
    ViewData["Title"] = "Мир животных";
}

<div class="main-place">
    <div class="green-title">
        <h2>О нашей планете</h2>
    </div>
    <hr class="green-line">
    <p>Земля населена миллионами удивительных существ. От крошечных насекомых до гигантских синих китов.</p>
    <div class="image-container">
        <img src="~/images/animal-world/animals.jpg" alt="Разнообразие животных на планете" />
    </div>
    <div class="index-actions">
        <a class="find-animal-button add-link-button" asp-controller="AnimalWorld" asp-action="Add">
            Перейти к добавлению данных
        </a>
    </div>

    <div class="green-title">
        <h2>Зоопарки</h2>
    </div>
    <hr class="green-line">
    @if (Model?.ZooList?.Any() == true)
    {
        @foreach (var zoo in Model.ZooList)
        {
            <div class="animal entity-card">
                <h3>@zoo.ZooName</h3>
                <p><strong>Адрес:</strong> @zoo.Address</p>
                <p>@zoo.Description</p>
            </div>
        }
    }
    else
    {
        <p class="empty-list-note">Пока нет данных о зоопарках.</p>
    }

    <div class="green-title">
        <h2>Роды животных</h2>
    </div>
    <hr class="green-line">
    @if (Model?.AnimalFamilyList?.Any() == true)
    {
        @foreach (var family in Model.AnimalFamilyList)
        {
            <div class="animal entity-card">
                <h3>@family.AnimalFamilyName</h3>
                <p>@family.Description</p>
            </div>
        }
    }
    else
    {
        <p class="empty-list-note">Пока нет данных о родах животных.</p>
    }

    <div class="green-title">
        <h2>Виды животных</h2>
    </div>
    <hr class="green-line">
    @if (Model?.AnimalSpeciesList?.Any() == true)
    {
        @foreach (var species in Model.AnimalSpeciesList)
        {
            <div class="animal entity-card">
                <h3>@species.AnimalSpeciesName</h3>
                <p><strong>Ареал:</strong> @species.NativeRange</p>
                <p>@species.Description</p>
            </div>
        }
    }
    else
    {
        <p class="empty-list-note">Пока нет данных о видах животных.</p>
    }
</div>
<div class="footer-body">
    <p>&copy; 2026 Мир Животных. Берегите природу!</p>
</div>