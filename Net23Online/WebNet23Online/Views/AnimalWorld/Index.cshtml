@model WebNet23Online.Models.AnimalWorld.StartPageAnimalsViewModel
@{
    Layout = "_LayoutAnimalWorld";
}

<title>Мир животных</title>

<div class="main-place">
    <div class="green-title">
        <h2>О нашей планете</h2>
    </div>
    <hr class="green-line">
    <p>Земля населена миллионами удивительных существ. От крошечных насекомых до гигантских синих китов.</p>
    <div class="image-container">
        <img src="~/images/animal-world/animals.jpg" />">
    </div>
    <div class="green-title">
        <h2>Братья наши меньшие</h2>
    </div>
    <hr class="green-line">
    @foreach (var animal in Model.Animals)
    {
        <div class="animal">
            <h3>@animal.BeastName</h3>
            <p>@animal.BriefDescription</p>
        </div>
    }
    <div class="green-title">
        <h2>Какое ваше любимое животное?</h2>
    </div>
    <div id="search-result-container">
        @await Html.PartialAsync("AnimalSearch", Model.Beast)
    </div>
    <hr class="green-line">
</div>
<div class="footer-body">
    <p>&copy; 2026 Мир Животных. Берегите природу!</p>
</div>