@model WebNet23Online.Models.AnimalWorld.BindZooFamilyViewModel
@{
    Layout = "_LayoutAnimalWorld";
    ViewData["Title"] = "Привязка зоопарка и родов";
    var zooOptions = ViewBag.ZooOptions as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
        ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
    var familyOptions = ViewBag.AnimalFamilyOptions as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>
        ?? Enumerable.Empty<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>();
}

<div class="main-place">
    <div class="green-title">
        <h2>Привязка зоопарка к родам животных</h2>
    </div>
    <hr class="green-line">
    <p>Сначала выберите зоопарк, затем один или несколько родов животных.</p>

    <form method="post" asp-controller="AnimalWorld" asp-action="BindZooFamily" class="entity-form">
        <div class="form-group">
            <div class="green-title">
                <h6>Зоопарк</h6>
            </div>
            @Html.DropDownListFor(zoo => zoo.ZooName, zooOptions, "Выберите зоопарк", new { @class = "form-input" })
        </div>

        <div class="form-group">
            <div class="green-title">
                <h6>Роды животных</h6>
            </div>
            @Html.ListBoxFor(binding => binding.AnimalFamilyNames, familyOptions, new { @class = "form-input multi-select-input" })
        </div>

        <div class="button-group">
            <button class="find-animal-button" type="submit">Сохранить привязку</button>
            <a class="find-animal-button add-link-button secondary-action" asp-controller="AnimalWorld" asp-action="Add">Назад</a>
        </div>
    </form>
</div>
