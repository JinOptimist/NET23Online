@model WebNet23Online.Models.AnimeGirl.HandMadeViewModel

@{
    Layout = "_LayoutAnime";
}
<link rel="stylesheet" href="/css/anime-girl/handmade.css">
<div>
    Привет @Model.Name Now is @Model.Minutes : @Model.Seconds
</div>
<div class="info">
    <img src="/images/anime-girl/logo.jpg" />
    <a href="/animeGirl/Index">Nice</a>
    <span>Smile Generator 1</span>
    <span>Smile Generator 2</span>
    <span>Smile Generator 3</span>
</div>
<div class="games">
    <form>
        <input maxlength="5" type="text" placeholder="Game Name" />
        <div>
            <label>
                <input type="checkbox" name="game-features" value="грабить коро" placeholder="Game Features" />
                грабить коро
            </label>
            <label>
                <input type="checkbox" name="game-features" value="грабить магазины" placeholder="Game Features" />
                грабить магазины
            </label>
            <label>
                <input type="checkbox" name="game-features" value="грабить банки" placeholder="Game Features" />
                грабить
                банки
            </label>
        </div>
        <div>
            <label>
                <input type="radio" name="main-character" value="грабить банки" placeholder="Game Type" />
                Мал
            </label>
            <label>
                <input type="radio" name="main-character" value="грабить магазины" placeholder="Game Type" />
                Дев
            </label>
        </div>
        <input type="color" />
        <input type="number" />
        <input type="range" />
        <div>
            <button type="submit">Add Game</button>
        </div>
    </form>
</div>
<div class="animes">
    <div class="anime">
        <div class="image-container">
            <img src="/images/anime-girl/girl1.jpg" />
        </div>
        <div class="anime-name">Anime 1</div>
    </div>
    <div class="anime">
        <div class="image-container">
            <img src="/images/anime-girl/girl2.jpg" />
        </div>
        <div class="anime-name">Anime 1</div>
    </div>
    <div class="anime">
        <div class="image-container">
            <img src="/images/anime-girl/girl3.jpg" />
        </div>
        <div class="anime-name">Anime 1</div>
    </div>
    <div class="anime">
        <div class="image-container">
            <img src="/images/anime-girl/girl4.jpg" />
        </div>
        <div class="anime-name">Anime 1</div>
    </div>
</div>

<div class="books">
    books info
</div>
