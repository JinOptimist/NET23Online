@using WebNet23Online.Models.Steam
@model SteamHomeViewModel
@{
    Layout = "_LayoutSteam";
}
<main class="page">
    <section class="section">
        <h1 class="page-title">Store</h1>
    </section>

    <section class="section">
        <h2 class="section-title">Featured</h2>
        @foreach (var game in Model.Featured)
        {
            <article class="feature-card">
                <div class="feature-media" aria-hidden="true">
                    <img src=@game.ImageUrl alt="Game Title cover" />
                </div>

                <div class="feature-content">
                    <h3 class="feature-title">@game.Title</h3>
                    <p class="feature-text">
                        @game.Description
                    </p>

                    <div class="feature-footer">
                        <span class="price">$@game.Price.ToString("0.00")</span>
                        <a class="btn" href="/app/123">View game</a>
                    </div>
                </div>
            </article>
        }
    </section>

    <section class="section">
        <h2 class="section-title">Special Offers</h2>

        <div class="cards">
            @foreach (var game in Model.SpecialOffers)
            {
                <article class="card">
                    <div class="card-media">
                        <img src=@game.ImageUrl />
                    </div>
                    <div class="card-body">
                        <h3 class="card-title">@game.Title</h3>
                        <div class="card-footer">
                            <span class="price">$@game.Price.ToString("0.00")</span>
                            <a class="btn btn--small" href="/app/1">View</a>
                        </div>
                    </div>
                </article>
            }
        </div>
    </section>
    <section class="section">
        <div>
            <a class="btn catalog-button" href="/Steam/Catalog">Catalog</a>
        </div>
    </section>
</main>
