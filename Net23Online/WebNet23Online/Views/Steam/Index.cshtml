@using WebNet23Online.Models.Steam
@model NameViewModel
@{
    Layout = "_LayoutSteam";
}
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Steam Homepage</title>
    <link rel="stylesheet" href="/css/steam/styles.css" />
</head>
<body>
    <header class="site-header">
        <div class="topbar">
            <a class="brand" href="/">STEAM</a>

            <nav class="primary-nav">
                <ul class="nav-list">
                    <li><a href="/store">Store</a></li>
                    <li><a href="/community">Community</a></li>
                    <li><a href="/about">About</a></li>
                    <li><a href="/support">Support</a></li>
                    <div>Hello,@Model.Name </div>
                </ul>
            </nav>

            <div class="topbar-actions">
                <form class="search">
                    <input name="q" type="search" placeholder="Search the store" />
                    <button type="submit">Search</button>
                </form>

                <a class="install" href="/install">Install Steam</a>
            </div>
        </div>
    </header>
    <main class="page">
        <section class="section">
            <h1 class="page-title">Store</h1>
        </section>

        <section class="section">
            <h2 class="section-title">Featured</h2>

            <article class="feature-card">
                <div class="feature-media" aria-hidden="true">
                    <img src="/images/steam/tlou-2.jpg" alt="Game Title cover" />
                </div>

                <div class="feature-content">
                    <h3 class="feature-title">The Last Of Us 2</h3>
                    <p class="feature-text">
                        The Last of Us Part II Remastered on Steam is a third-person, action-adventure survival horror game where Ellie seeks justice in a post-apocalyptic USA five years after the original, featuring intense combat, stealth, and a deeply emotional story.
                    </p>

                    <div class="feature-footer">
                        <span class="price">$79.99</span>
                        <a class="btn" href="/app/123">View game</a>
                    </div>
                </div>
            </article>
        </section>

        <section class="section">
            <h2 class="section-title">Special Offers</h2>

            <div class="cards">
                <article class="card">
                    <div class="card-media">
                        <img src="/images/steam/bg3.jpg" />
                    </div>
                    <div class="card-body">
                        <h3 class="card-title">Baldurs Gate 3</h3>
                        <div class="card-footer">
                            <span class="price">$29.99</span>
                            <a class="btn btn--small" href="/app/1">View</a>
                        </div>
                    </div>
                </article>

                <article class="card">
                    <div class="card-media">
                        <img src="/images/steam/crysis-3.jpg" />
                    </div>
                    <div class="card-body">
                        <h3 class="card-title">Crysis 3</h3>
                        <div class="card-footer">
                            <span class="price">$9.99</span>
                            <a class="btn btn--small" href="/app/2">View</a>
                        </div>
                    </div>
                </article>

                <article class="card">
                    <div class="card-media">
                        <img src="/images/steam/witcher3.jpg" />
                    </div>
                    <div class="card-body">
                        <h3 class="card-title">The Witcher 3: Wild Hunt</h3>
                        <div class="card-footer">
                            <span class="price">$20.99</span>
                            <a class="btn btn--small" href="/app/3">View</a>
                        </div>
                    </div>
                </article>

                <article class="card">
                    <div class="card-media">
                        <img src="/images/steam/hollow-knight.jpg" />
                    </div>
                    <div class="card-body">
                        <h3 class="card-title">Hollow Knight</h3>
                        <div class="card-footer">
                            <span class="price">$14.99</span>
                            <a class="btn btn--small" href="/app/4">View</a>
                        </div>
                    </div>
                </article>

                <article class="card">
                    <div class="card-media">
                        <img src="/images/steam/hollow-knight-silksong.jpg" />
                    </div>
                    <div class="card-body">
                        <h3 class="card-title">Hollow Knight: Silksong</h3>
                        <div class="card-footer">
                            <span class="price">$29.99</span>
                            <a class="btn btn--small" href="/app/5">View</a>
                        </div>
                    </div>
                </article>

                <article class="card">
                    <div class="card-media">
                        <img src="/images/steam/tlou-1.jpg" />
                    </div>
                    <div class="card-body">
                        <h3 class="card-title">The Last Of Us</h3>
                        <div class="card-footer">
                            <span class="price">$60.00</span>
                            <a class="btn btn--small" href="/app/6">View</a>
                        </div>
                    </div>
                </article>
            </div>
        </section>
    </main>
    <footer></footer>
</body>
</html>
