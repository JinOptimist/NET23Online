@using WebNet23Online.Models.Steam
@model CatalogViewModel
@{
    Layout = "_LayoutSteam";
}
<main class="page">
    <section class="section">
        <div class="catalog-header">
            <h1 class="page-title">Catalog</h1>
            <div class="catalog-actions">
                <p><a class="btn" href="/Steam/Index">← Back to store</a></p>
                <a class="btn btn--primary" href="/Steam/AddGame">+ Add New Game</a>
            </div>
        </div>
    </section>

    <section class="section">
        <h2 class="section-title">Filter</h2>
        <form method="post">
            <div class="form-group">
                <label>Genre</label>
                <select name="GenreId" class="form-control">
                    <option value="">-- All genres --</option>
                    @foreach (var genre in Model.GameGenres)
                    {
                        <option value="@genre.Value" selected="@(Model.Filter.GenreId?.ToString() == genre.Value ? "selected" : null)">
                            @genre.Text
                        </option>
                    }
                </select>
            </div>

            <div class="form-group">
                <label>Max price</label>
                <input type="number" name="MaxPrice" step="0.01" class="form-control"
                       value="@Model.Filter.MaxPrice" />
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn--primary">Apply</button>
                <a href="/Steam/Catalog" class="btn">Reset</a>
            </div>
        </form>
    </section>

    <section class="section">
        <h2 class="section-title">All games (@Model.Games.Count)</h2>

        <div class="cards">
            @foreach (var game in Model.Games)
            {
                <article class="card">
                    <div class="card-media">
                        <img src="@game.ImageUrl" alt="@game.Title" />
                    </div>
                    <div class="card-body">
                        <h3 class="card-title">@game.Title</h3>
                        @if (game.Genres != null && game.Genres.Any())
                        {
                            <div class="feature-genres">
                                @foreach (var genre in game.Genres)
                                {
                                    <span class="game-genre">@genre</span>
                                }
                            </div>
                        }
                        <div class="card-footer">
                            <span class="price">$@game.Price.ToString("0.00")</span>
                            <a class="btn btn--small" href="/Steam/GameDetails/@game.Id">View</a>
                        </div>
                    </div>
                </article>
            }
        </div>
    </section>
</main>