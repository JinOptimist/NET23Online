@using WebNet23Online.Models.Steam
@model GameDetailsViewModel
@{
    Layout = "_LayoutSteam";
}

<main class="page">
    <section class="section">
        <div class="game-header">
            <a class="btn" href="/Steam/Catalog">← Back to Catalog</a>
            <a class="btn btn--edit" href="/Steam/EditGame/@Model.Id">✎ Edit Game</a>
        </div>
    </section>

    <section class="section">
        <div class="game-container">

            <div class="game-image">
                <img src="@Model.ImageUrl" alt="@Model.Title" />
            </div>

            <div class="game-info">
                <h1 class="game-title">@Model.Title</h1>

                <div class="game-meta">
                    @foreach(var genre in Model.Genres)
                    {
                        <span class="game-genre">@genre</span>
                    }
                    
                    @if (!string.IsNullOrEmpty(Model.PublisherName))
                    {
                        <span class="game-publisher">@Model.PublisherName</span>
                    }
                </div>

                <div class="game-price">
                    @if (Model.Price > 0)
                    {
                        <span>$@Model.Price.ToString("0.00")</span>
                    }
                    else
                    {
                        <span class="free">Free</span>
                    }
                </div>

                <div class="game-description">
                    <h3>About this game</h3>
                    <p>@Model.Description</p>
                </div>

                <div class="game-actions">
                    <button class="btn btn--primary">Add to Cart</button>
                    <button class="btn">Add to Wishlist</button>
                </div>
            </div>
        </div>
    </section>
</main>