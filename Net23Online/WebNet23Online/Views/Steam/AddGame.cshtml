@using WebNet23Online.Localizations.Steam
@using WebNet23Online.Models.Steam
@model AddGameViewModel
@{
    Layout = "_LayoutSteam";
}
<main class="page">
    <section class="section">
        <h1 class="page-title">@AddGamePage.Page_Title</h1>
        <div class="catalog-header">
            <p><a class="btn" href="/Steam/Catalog">← @AddGamePage.Back_To_Catalog_Button</a></p>
        </div>
    </section>

    <section class="section">
        <form method="post">
            <div class="form-group">
                @Html.LabelFor(x => x.Title, AddGamePage.Label_Title)
                @Html.ValidationMessageFor(x => x.Title)
                @Html.TextBoxFor(x => x.Title, new {
                @class = "form-control",
                                placeholder = AddGamePage.Title_Area_Placeholder,
                                required = "required"
                                })
            </div>

            <div class="form-group">
                @Html.LabelFor(x => x.ImageUrl, AddGamePage.Label_Image_URL)
                @Html.ValidationMessageFor(x => x.ImageUrl)
                @Html.TextBoxFor(x => x.ImageUrl, new {
                                @class = "form-control",
                                placeholder = "https://example.com/image.jpg",
                                type = "url"
                                })
            </div>

            <div class="form-group">
                @Html.LabelFor(x => x.Description, AddGamePage.Label_Description)
                @Html.ValidationMessageFor(x => x.Description)
                @Html.TextAreaFor(x => x.Description, new {
                                @class = "form-control",
                                rows = "5",
                                placeholder = AddGamePage.Description_Area_Placeholder
                                })
            </div>

            <div class="form-group">
                @Html.LabelFor(x => x.Price, AddGamePage.Label_Price + "($)")
                @Html.ValidationMessageFor(x => x.Price)
                @Html.TextBoxFor(x => x.Price, new {
                                @class = "form-control",
                                placeholder = "0.00",
                                type = "number",
                                step = "0.01",
                                required = "required"
                                })
            </div>

            <div class="form-group">
                @Html.LabelFor(x => x.SelectedGenreIds, AddGamePage.Label_Genres)
                <select id="SelectedGenreIds" name="SelectedGenreIds" class="form-control" multiple required>
                    @foreach (var genre in Model.AllGenres)
                    {
                        <option value="@genre.Value">@genre.Text</option>
                    }
                </select>
                <small class="form-text text-muted">@AddGamePage.Genre_Hint_Text</small>
            </div>

            <div class="form-group">
                @Html.LabelFor(x => x.PublisherId, AddGamePage.Label_Publisher)
                <select id="PublisherId" name="PublisherId" class="form-control">
                    @foreach (var publisher in Model.Publishers)
                    {
                        <option value="@publisher.Value" selected="@publisher.Selected">
                            @publisher.Text
                        </option>
                    }
                </select>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn--primary">@AddGamePage.Save_Game_Button</button>
                <a href="/Steam/Catalog" class="btn">@AddGamePage.Cancel_Button</a>
            </div>
        </form>
    </section>
</main>