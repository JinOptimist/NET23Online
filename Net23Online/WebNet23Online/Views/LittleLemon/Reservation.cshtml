@using WebNet23Online.Models.LittleLemon
@model LittleLemonReservationPageViewModel
@{
	Layout = "_LayoutLittleLemon";
}
<title>Reservation</title>
@Html.Partial("_LittleLemonHeroSection", Model.Hero)
<section class="booking-section">
	<h2>Choose Your Loving Place!</h2>
	
	<form class="booking-form" method="post" asp-controller="LittleLemon" asp-action="CreateGuest">
		<div>
			<label for="guest-name">Create new guest (name):</label>
			<input type="text" id="guest-name" asp-for="Reservation.GuestName" required />
			<div asp-validation-for="Reservation.GuestName"></div>
		</div>
		<input type="submit" value="Create guest and get GuestId" class="btn" />
	</form>
	<form class="booking-form" method="post" asp-controller="LittleLemon" asp-action="Reservation">
		<div>
			<label for="guest-id">Guest Id :</label>
			<input type="number"
				   id="guest-id"
				   name="GuestId"
				   min="1"
				   value="@(Model.Reservation.GuestId > 0 ? Model.Reservation.GuestId : null)"
				   required />
		</div>
		<div>
			
			<label for="reserve-date">Choose Date:</label>
			<input type="date" id="reserve-date" asp-for="Reservation.ReservationDateOnly" required />
			<div asp-validation-for="Reservation.ReservationDateOnly"></div>
		</div>
		<div>
			<label for="reserve-time">Choose Time:</label>
			<select id="reserve-time" asp-for="Reservation.AvailableTimesOnly" required>
				<option value="17:00">17:00</option>
				<option value="18:00">18:00</option>
				<option value="19:00">19:00</option>
				<option value="20:00">20:00</option>
				<option value="21:00">21:00</option>
				<option value="22:00">22:00</option>
			</select>
			<div asp-validation-for="Reservation.AvailableTimesOnly"></div>
		</div>
		<div>
			<label for="guests">Number of Guests:</label>
			<input type="number"
				   placeholder="1"
				   min="1"
				   max="10"
				   id="guests"
				   asp-for="Reservation.NumberOfGuests"
				   required />
			<div asp-validation-for="Reservation.NumberOfGuests"></div>
		</div>
		<div>
			<label for="seating">Seating preference:</label>
			<select id="seating" asp-for="Reservation.SeatingPreference" required>
				<option value="no-preference">No preference</option>
				<option value="indoor">Indoor dining room</option>
				<option value="patio">Patio / outdoor</option>
				<option value="window">Window table (if available)</option>
			</select>
			<div asp-validation-for="Reservation.SeatingPreference"></div>
		</div>
		<div>
			<label for="occasion">Occasion:</label>
			<div>
				<select id="occasion" asp-for="Reservation.Occasion" required>
					<option value="none">None</option>
					<option value="birthday">Birthday</option>
					<option value="anniversary">Anniversary</option>
					<option value="other">Other</option>
				</select>
				<div asp-validation-for="Reservation.Occasion"></div>
			</div>

		</div>
		<div>
			<label for="text-area"> Do You want to add anything else ? </label>
			<textarea asp-for="Reservation.UserComments" id="text-area" cols="2" rows="3" placeholder="Remember, be nice!"
					  required></textarea>
			<div asp-validation-for="Reservation.UserComments"></div>
		</div>
		<input type="submit" value="Make your reservation" class="btn" />
	</form>
</section>
