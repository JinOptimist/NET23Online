@using System.Linq
@using WebNet23Online.Models.LittleLemon
@model LittleLemonHistoryPageViewModel
@{
	Layout = "_LayoutLittleLemon";
}
<title>Reservation History</title>
@Html.Partial("_LittleLemonHeroSection", Model.Hero)

<section class="booking-form confirmation-list">
	<h2>Your reservation history</h2>

	@if (Model.Reservations == null || !Model.Reservations.Any())
	{
		<p>No reservations found.</p>
	}
	else
	{
		<ul>
			@foreach (var item in Model.Reservations)
			{
				<li>
					<strong>#@item.ReservationId</strong> —
					@item.Reservation.ReservationDateOnly @item.Reservation.AvailableTimesOnly,
					Guests: @item.Reservation.NumberOfGuests,
					Seating: @item.Reservation.SeatingPreference,
					Name: @item.Reservation.GuestName
				</li>
			}
		</ul>
	}
</section>