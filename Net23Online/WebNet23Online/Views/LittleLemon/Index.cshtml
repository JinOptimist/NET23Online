@using WebNet23Online.Models.LittleLemon
@model LittleLemonIndexPageViewModel
@{
    Layout = "_LayoutLittleLemon";
}
<title>Little Lemon Restaurant</title>

@Html.Partial("_LittleLemonHeroSection", Model.Hero)
<section id="menu" class="menu-section">
    <div class="menu-container">
        <div class="menu-content">
            <h2 class="menu-heading-lg">This week’s specials!</h2>
            <div class="menu-button">
                <a href="menu.html" class="btn">View Full Menu</a>
            </div>
        </div>
        <div class="menu-filter-items">
            <a href="/LittleLemon/Index" class="btn-filter">Mains</a>
            <a href="/LittleLemon/Index/?category=Lunch" class="btn-filter">Lunch</a>
            <a href="/LittleLemon/Index/?category=Desserts" class="btn-filter">Desserts</a>
            <a href="/LittleLemon/Index/?category=Specials" class="btn-filter">Specials</a>
            <a href="/LittleLemon/Index/?category=Drinks" class="btn-filter">Drinks</a>
        </div>
        <div class="menu-item-container">
            @foreach (var menuItem in Model.MenuItems)
            {
                <div class="menu-item-content">
                    <div class="menu-item-img-container">
                        <img src="@menuItem.ImageUrl" alt="@menuItem.Name" class="img" />
                    </div>
                    <h3>@menuItem.Name</h3>
                    <p>@menuItem.Price<span>$</span></p>
                    <p class="menu-description">
                        @menuItem.Description
                    </p>
                    <button type="button" class="btn-order svg-hover">
                        Order delivery
                        <svg width="18" height="11" viewBox="0 0 18 11" xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M14.8035 1.72707C14.8035 0.899239 14.0532 0.221924 13.1363 0.221924H10.6355V1.72707H13.1363V3.72138L10.2354 6.99507H7.3011V3.23221H3.96671C2.12446 3.23221 0.632324 4.57932 0.632324 6.2425V8.50022H2.29952C2.29952 9.74949 3.41654 10.7579 4.80031 10.7579C6.18408 10.7579 7.3011 9.74949 7.3011 8.50022H11.0356L14.8035 4.24819V1.72707ZM4.80031 9.25279C4.34183 9.25279 3.96671 8.91413 3.96671 8.50022H5.63391C5.63391 8.91413 5.25879 9.25279 4.80031 9.25279Z" />
                            <path d="M7.30106 0.974487H3.13306V2.47961H7.30106V0.974487Z" />
                            <path
                                d="M14.8035 6.24249C13.4198 6.24249 12.3027 7.25093 12.3027 8.5002C12.3027 9.74946 13.4198 10.7579 14.8035 10.7579C16.1873 10.7579 17.3043 9.74946 17.3043 8.5002C17.3043 7.25093 16.1873 6.24249 14.8035 6.24249ZM14.8035 9.25277C14.345 9.25277 13.9699 8.91411 13.9699 8.5002C13.9699 8.08629 14.345 7.74763 14.8035 7.74763C15.262 7.74763 15.6371 8.08629 15.6371 8.5002C15.6371 8.91411 15.262 9.25277 14.8035 9.25277Z" />
                        </svg>
                    </button>
                </div>
            }
        </div>
    </div>
</section>
<section class="testimonials-section">
    <h2>What our customers say!</h2>
    <div class="testimonials-container">
        @foreach (var testimonial in Model.Testimonials)
        {
            <div class="rate-card">
                <div class="stars">
                    <span class="stars-description">@testimonial.StarsDescription</span>
                    @for (var starIndex = 0; starIndex < testimonial.StarRating; starIndex++)
                    {
                        <img src="@LittleLemonTestimonialViewModel.StarIconRelativeUrl" alt="star" />
                    }
                </div>
                <div class="testimonial-user-info">
                    <div class="user-image">
                        <img src="@testimonial.UserPhotoUrl" alt="@testimonial.UserPhotoAlt" class="img" />
                    </div>
                    <div class="user-info">
                        <h5>@testimonial.AuthorDisplayName</h5>
                        <p class="nick-name">@testimonial.AuthorNickName</p>
                    </div>
                </div>
                <p class="rate-description">
                    “@testimonial.Quote”
                </p>
            </div>
        }
    </div>
</section>
<section id="about" class="about-us-section">
    <h2>About Us</h2>
    <div class="about-us-container">
        <div class="about-us-content-left">
            <h3 class="about-us-title">Our Story</h3>
            <div class="about-us-content-text">
                <p>
                    Little Lemon began as a simple idea in Chicago: bring the warmth
                    of a Mediterranean kitchen to a city that loves bold flavor and
                    honest hospitality. We are a family-owned restaurant, and many
                    of our dishes still start with recipes passed down through
                    generations—then refined with seasonal ingredients and a
                    contemporary eye for balance and presentation.
                </p>
                <p>
                    From Greek salad with our house feta to slow-cooked tagines and
                    bright, citrus-forward desserts, we cook food meant to be
                    shared. Our dining room is relaxed and welcoming, whether you
                    are here for a quick lunch, a long dinner with friends, or a
                    celebration with the people who matter most.
                </p>
                <p>
                    We are proud to be part of Chicago’s diverse food scene and
                    grateful to the neighbors and visitors who have made Little
                    Lemon a gathering place. We look forward to serving you soon.
                </p>
            </div>
        </div>
        <div class="about-us-image-container">
            <div class="about-img-right">
                <img src="/images/little-lemon/images/loby.jpg" alt="Restaurant lobby" class="img" />
            </div>
            <div class="about-img-left">
                <img src="/images/little-lemon/images/hall.jpg" alt="Restaurant hall" class="img" />
            </div>
        </div>
    </div>
</section>
