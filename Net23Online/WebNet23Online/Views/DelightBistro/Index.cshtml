@using WebNet23Online.Models.DelightBistro;
@using WebNet23Online.Localizations;


@{
    Layout = "_LayoutDelightBistro";
}
@model List<MenuTypeViewModel>

<link rel="stylesheet" href="\css\delight-bistro\style.css" />
 
<header class="head-menu">
    <div class="logo-container">
        <div class="logo">
            <img src="/images/delight-bistro/logo.png" alt="logo" />
        </div>
        <div class="logo-name">Logo name</div>
    </div>
    <div class="main-info center">
        <div class="head-menu-item">Info</div>
        <div class="head-menu-item">Head menu</div>
    </div>
</header>

<h1 class="center">@DelightBistro.Index_Cuisine</h1>

<div class="layout">
    <div class="plate">

        @foreach (var category in Model)
        {
            if ((category.FoodItems).Any())
            {
                <div class="type-of-food">
                    <div class="type-name center">
                        @category.Name @if(category.Creator!=null) {
                        <div> (Creator: @category.Creator)</div>
                    }
                </div>
                <div class="menu">
                    @foreach (var foodItem in category.FoodItems)
                    {
                        <div class="food-item" item-id="@foodItem.Id">
                            @if (foodItem.Creator != null)
                            {
                                <div> Creator: @foodItem.Creator</div>
                            }
                            <div class="image-container">
                                <a href="\DelightBistro\FoodBuilderData?id=@foodItem.Id"><img src=@foodItem.ImgURL alt=@foodItem.Name /></a>
                            </div>
                            <div class="name-price-btn">
                                <div class="name-price">
                                    <div class="food-name">@foodItem.Name</div>
                                    <div class="price">@foodItem.Price р</div>
                                </div>
                                <div class="btnright">
                                    <button class="add-button colorbtn">+</button>
                                </div>
                            </div>
                            <div class="recept">
                                <ul>
                                    @if (foodItem.Ingredients is not null)
                                    {
                                        @foreach (var ingredient in foodItem.Ingredients)
                                        {
                                            <li>@ingredient</li>
                                        }
                                    }
                                </ul>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>
        
<aside class="right-bar">
    <div class="form-field">
        <form method="post">
            <div class="userName">Username</div>
            <input type="text"
                   name="username"
                   placeholder="Введите логин"
                   required />

            <div>Password</div>
            <input type="password"
                   name="userPassword"
                   placeholder="Введите пароль"
                   required />
            <button type="submit">Войти</button>
        </form>
    </div>

    <ul class="navigation">
        <li><a href="\DelightBistro\Index">@DelightBistro.Index_All_menu</a> </li>

        @foreach (var menu in Model)
        {
            <li><a href="\DelightBistro\Index?menutype=@menu.Name">@menu.Name</a> </li>

        }
        <br>
            
        <br>
        <li><a href="\DelightBistro\CreateMenu">@DelightBistro.Index_Create_menu</a> </li>
        <li><a href="\DelightBistro\CreateIngredient">@DelightBistro.Index_Create_ingredient</a> </li>
        <li><a href="\DelightBistro\FoodBuilderData">@DelightBistro.Index_Create_dish</a> </li>
        <br>
        <li><a href="\DelightBistro\AllFoodItems">@DelightBistro.Index_All_dish</a> </li>



    </ul>
</aside>
</div>

