@using WebNet23Online.Models.DelightBistro;

@{
    Layout = "_LayoutimagesDelightBistro";
}
@model List<FoodItemViewModel>

<link rel="stylesheet" href="\css\delight-bistro\style.css" />
 
<header class="head-menu">
    <div class="logo-container">
        <div class="logo">
            <img src="/images/delight-bistro/logo.png" alt="logo" />
        </div>
        <div class="logo-name">Logo name</div>
    </div>
    <div class="main-info center">
        <div class="head-menu-item">Info</div>
        <div class="head-menu-item">Head menu</div>
    </div>
</header>

<h1 class="center">Кухня</h1>

<div class="layout">
    <div class="plate">
                
        <div class="type-of-food">
            <div class="type-name center">Все блюда</div>
            <div class="menu">

                @foreach (var food in Model)
                {
                    <div class="food-item" item-id="@food.Id">
                        <div class="image-container">
                            <a href="\DelightBistro\FoodBuilderData?id=@food.Id"><img src=@food.ImgURL alt=@food.Name /></a>
                        </div>
                        <div class="name-price-btn">
                            <div class="name-price">
                                <div class="food-name">@food.Name</div>
                                <div class="price">@food.Price р</div>
                            </div>
                            <div class="btnright">
                                <button class="add-button colorbtn">+</button>
                            </div>
                        </div>
                        <div class="recept">
                            <ul>
                                @if (food.Ingredients is not null)
                                {
                                    @foreach (var ingredient in food.Ingredients)
                                    {
                                        <li>@ingredient</li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
        
    <aside class="right-bar">
        <div class="form-field">
            <form method="post">
                <div class="userName">Username</div>
                <input type="text"
                       name="username"
                       placeholder="Введите логин"
                       required />

                <div>Password</div>
                <input type="password"
                       name="userPassword"
                       placeholder="Введите пароль"
                       required />
                <button type="submit">Войти</button>
            </form>
        </div>

        <ul class="navigation">
            <li><a href="\DelightBistro\Index">Все меню</a> </li>
        </ul>
    </aside>
</div>

