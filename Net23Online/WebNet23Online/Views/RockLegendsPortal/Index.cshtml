             <div class="poll-container">
                     <p>@RockLegendsPortal.Survey</p>
    
                 <form asp-controller="RockLegendsPortal" asp-action="Index" method="post">
                     <div class="poll-controls">
                        <span class="easter-egg">@RockLegendsPortal.Easter_egg</span>
                        <select name="SelectedBandId" id="rock-poll">
                              <option value="2">KISS</option>
                              <option value="3">Ozzy Osbourne</option>
                              <option value="4">AC/DC</option>
                              <option value="5">Bon Jovi</option>
                              <option value="6">Rammstein</option>
                              <option value="7">Three Days Grace</option>
                              <option value="8">Slipknot</option>
                              <option value="9">Skillet</option>
                              <option value="10">Metallica</option>
                              <option value="11">Bring Me The Horizon</option>
