    <script>
            function toggleGroup(element, videoUrl) {
                const description = element.querySelector('.rockStar-description');
                const videoElement = document.getElementById('groupVideo');
                const videoSource = document.getElementById('videoSource');
        
                const isOpening = description.style.display !== "block";

                document.querySelectorAll('.rockStar-description').forEach(desc => {
                    desc.style.display = "none";
                });

                if (isOpening) {
                    description.style.display = "block";
            
                    videoSource.src = videoUrl;
            
                    videoElement.load();
                    videoElement.play();
                } else {
                    description.style.display = "none";
                    videoElement.pause();
                    videoSource.src = "";
                }
            }
    </script>