@using WebNet23Online.Models.RockLegendsPortal
@model RockLegendsPortalViewModel

@{
    Layout = "_LayoutRockLegends";
    ViewData["Title"] = Model.BandName;
}

<div class="main-container" style="padding: 20px; color: white;">
    
    <h1 style="color: #e61919; text-transform: uppercase; font-size: 3rem;">
        @Model.BandName
    </h1>
    
    <div class="content-box" style="background: rgba(0,0,0,0.6); padding: 20px; border-radius: 10px; border-left: 5px solid #e61919; margin-top: 20px;">
        <h3 style="color: #fff;">История и биография</h3>
        
        <p style="color: #ccc; line-height: 1.8; font-size: 1.2rem; white-space: pre-line;">
            @Model.Biography
        </p>
    </div>

    <div style="margin-top: 30px;">
        <p style="color: #666; font-size: 0.9rem;">
            Данная группа была выбрана: @Model.PickTime
            Технический код выбора: @Model.SelectedBand
        </p>
        
        <a href="/RockLegendsPortal/Index" class="poll-button" style="text-decoration: none; display: inline-block;">
            Вернуться в портал
        </a>
    </div>
</div>