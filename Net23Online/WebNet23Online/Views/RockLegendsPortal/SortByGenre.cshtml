@model WebNet23Online.Models.RockLegendsPortal.SortByGenreViewModel
@{
    Layout = "_LayoutRockLegends";
}
<link rel="stylesheet" href="/css/rock-legends-portal/style.css">

<div class="main-container">
    <div class="content-wrapper" style="flex-direction: column; align-items: center;">
        
        <div class="poll-container" style="margin-bottom: 50px; width: 100%; max-width: 600px;">
            <p>Связать группу с жанром</p>
            <form asp-action="LinkGroupToGenre" method="post">
                <div class="poll-controls">
                    @Html.DropDownListFor(x => x.SelectedBandId, Model.Bands, "Выберите группу", new { @class = "form-control" })
                    
                    @Html.DropDownListFor(x => x.SelectedGenreId,
                        Model.Genres.Select(g => new SelectListItem { Text = g.Name, Value = g.Id.ToString() }),
                        "Выберите жанр",
                        new { @class = "form-control" })

                    <button type="submit" class="poll-button">Связать</button>
                </div>
            </form>
        </div>

        <div class="genres-list" style="width: 100%; max-width: 800px;">
            @foreach (var genre in Model.Genres)
            {
                <div class="genre-item" style="margin-bottom: 15px; display: flex; gap: 10px;">
        
                    <button class="poll-button genre-toggle-button" style="flex-grow: 1;"
                            onclick="toggleGenre('@genre.Id')">
                        @genre.Name (Групп: @genre.BandNames.Count)
                    </button>

                    @if (Model.IsCurrentUserAdmin)
                    {
                        <form asp-action="DeleteGenre" asp-route-id="@genre.Id" method="post"
                              onsubmit="return confirm('Удалить жанр и все связи?')">
                            <button type="submit" class="poll-button delete-genre-btn">
                                ❌
                            </button>
                        </form>
                    }
                </div>
    
                <div id="genre-@genre.Id" class="genre-content-box">
                    @if (genre.BandNames.Any())
                    {
                        foreach (var bandName in genre.BandNames)
                        {
                            <div class="band-name-item">🎸 @bandName</div>
                        }
                    }
                    else
                    {
                        <div class="empty-genre-msg">В этом жанре пока нет групп.</div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<script>
    function toggleGenre(id) {
        const element = document.getElementById('genre-' + id);
        element.style.display = (element.style.display === "none") ? "block" : "none";
    }
</script>
